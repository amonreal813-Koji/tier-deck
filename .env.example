# Copy this file to .env and fill in what you have.
# Restart `npx expo start` after any change here.

# Video games — REQUIRED for the games category.
# Free key, ~1 minute signup: https://rawg.io/apidocs
EXPO_PUBLIC_RAWG_KEY=

# Movies & TV — OPTIONAL. Without it the app falls back to iTunes movie
# search (works fine, just less TV coverage).
# Free key: https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_KEY=

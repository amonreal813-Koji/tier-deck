# Copy this file to .env and fill in what you have. Everything is optional —
# the app runs without any of these. Restart `npx expo start` after changes.
#
# NOTE: EXPO_PUBLIC_* values are bundled into the app and visible to users.
# That's expected for affiliate tags (they ride in the URL anyway). Never put
# a secret you must keep private here.

# ─────────────────────────────────────────────────────────────
#  MONEY — affiliate tags. Fill these in to earn commission.
#  Links work without them; they just don't pay until set.
# ─────────────────────────────────────────────────────────────

# Amazon Associates — START HERE. Free signup, ~10 min.
# https://affiliate-program.amazon.com  →  your tag looks like "yourname-20"
# Powers "Shop" buttons on sneakers, watches, snacks, board games, and more.
EXPO_PUBLIC_AMAZON_TAG=

# Best Buy (phones, game consoles) — via Impact/CJ. Optional, add later.
EXPO_PUBLIC_BESTBUY_TAG=

# Sephora (makeup, fragrances) — via Rakuten. Optional, add later.
EXPO_PUBLIC_SEPHORA_TAG=

# Chewy (dog & cat lists) — via Partnerize. Optional, add later.
EXPO_PUBLIC_CHEWY_TAG=

# ─────────────────────────────────────────────────────────────
#  DATA — richer search results. All optional & free.
# ─────────────────────────────────────────────────────────────

# Video games — richer box art in the Games search.
# Without it, games fall back to Wikipedia (still works).
# Free key, ~1 minute: https://rawg.io/apidocs
EXPO_PUBLIC_RAWG_KEY=

# Movies & TV — better TV coverage in search.
# Without it, the app falls back to Wikipedia / iTunes (works fine).
# Free key: https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_KEY=
